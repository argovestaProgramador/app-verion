<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Fondo líquido shader WebGL -->
    <com.verion.practicas.LiquidGLView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Overlay oscuro suave para legibilidad -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#3A000000" />

    <!-- Contenido principal -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="72dp"
            android:paddingBottom="36dp"
            android:paddingHorizontal="28dp">

            <!-- ── Marca ─────────────────────────────────── -->

            <ImageView
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:src="@drawable/ic_logo_verion"
                android:contentDescription="@string/app_name" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/app_name"
                android:textColor="@color/text_white"
                android:textSize="38sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/tagline"
                android:textColor="#80FFFFFF"
                android:textSize="13sp" />

            <!-- ── Formulario ─────────────────────────────── -->

            <Space android:layout_height="52dp" android:layout_width="wrap_content" />

            <!-- Input email (underline) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_email"
                        android:alpha="0.5"
                        android:contentDescription="@null" />

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="14dp"
                        android:background="@null"
                        android:hint="@string/email_hint"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionNext"
                        android:textColor="@color/text_white"
                        android:textColorHint="#55FFFFFF"
                        android:textSize="15sp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#35FFFFFF" />

            </LinearLayout>

            <Space android:layout_height="20dp" android:layout_width="wrap_content" />

            <!-- Input password (underline) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_lock"
                        android:alpha="0.5"
                        android:contentDescription="@null" />

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="match_parent"
                        android:layout_marginStart="14dp"
                        android:background="@null"
                        android:hint="@string/password_hint"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"
                        android:textColor="@color/text_white"
                        android:textColorHint="#55FFFFFF"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/ivEyeToggle"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_visibility"
                        android:alpha="0.4"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="Mostrar contraseña" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#35FFFFFF" />

            </LinearLayout>

            <!-- ── Botón principal ────────────────────────── -->

            <Space android:layout_height="40dp" android:layout_width="wrap_content" />

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_button_white"
                android:text="@string/btn_login"
                android:textColor="#1A0F3D"
                android:textSize="15sp"
                android:textStyle="bold"
                android:stateListAnimator="@null" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="12dp"
                android:indeterminateTint="@color/text_white"
                android:visibility="gone"
                style="?attr/progressBarStyle" />

            <!-- ── Divisor ─────────────────────────────────── -->

            <Space android:layout_height="28dp" android:layout_width="wrap_content" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#25FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="14dp"
                    android:text="@string/or_divider"
                    android:textColor="#45FFFFFF"
                    android:textSize="12sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#25FFFFFF" />

            </LinearLayout>

            <!-- ── Botón Google ───────────────────────────── -->

            <Space android:layout_height="20dp" android:layout_width="wrap_content" />

            <Button
                android:id="@+id/btnGoogle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_button_google"
                android:drawableStart="@drawable/ic_google"
                android:drawablePadding="10dp"
                android:text="@string/btn_google"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:stateListAnimator="@null"
                android:gravity="center" />

            <!-- ── Links secundarios ──────────────────────── -->

            <Space android:layout_height="32dp" android:layout_width="wrap_content" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_account"
                    android:textColor="#65FFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvRegisterLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/register_link"
                    android:textColor="@color/brand_primary_light"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- ── Modo invitado ──────────────────────────── -->

            <Space android:layout_height="24dp" android:layout_width="wrap_content" />

            <!-- Línea divisor sutil -->
            <View
                android:layout_width="40dp"
                android:layout_height="1dp"
                android:layout_gravity="center_horizontal"
                android:background="#20FFFFFF" />

            <Space android:layout_height="18dp" android:layout_width="wrap_content" />

            <TextView
                android:id="@+id/tvGuestMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="@string/guest_mode"
                android:textColor="#42FFFFFF"
                android:textSize="13sp"
                android:paddingVertical="10dp"
                android:paddingHorizontal="20dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </ScrollView>

</FrameLayout>
