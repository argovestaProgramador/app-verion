<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@null"
    android:overScrollMode="never"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="60dp"
        android:paddingBottom="100dp"
        android:paddingHorizontal="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Explorar técnicos"
            android:textColor="#FFFFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Encuentra el talento que necesitas"
            android:textColor="#70FFFFFF"
            android:textSize="13sp" />

        <!-- Barra de búsqueda glass -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_glass_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_nav_search"
                android:alpha="0.5"
                android:contentDescription="@null" />

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:background="@null"
                android:hint="Buscar por habilidad..."
                android:textColor="@color/white"
                android:textColorHint="#50FFFFFF"
                android:textSize="14sp"
                android:imeOptions="actionSearch"
                android:inputType="text" />

        </LinearLayout>

        <!-- Chips de categoría -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="4dp">

                <TextView
                    android:id="@+id/chipTodos"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip_selected"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Todos"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chipInformatica"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Informática"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chipDiseno"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Diseño"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chipMecanica"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Mecánica"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chipElec"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Electricidad"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Sección destacados -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="14dp"
            android:text="Técnicos destacados"
            android:textColor="#90FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <!-- Card 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_glass_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_avatar"
                android:gravity="center"
                android:text="C"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Carlos M."
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Técnico en Informática"
                    android:textColor="#70FFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="★ 5.0  ·  Lima, Perú"
                    android:textColor="#3B82F6"
                    android:textSize="11sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Card 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_glass_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_avatar"
                android:gravity="center"
                android:text="A"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ana R."
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Diseñadora Gráfica"
                    android:textColor="#70FFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="★ 4.2  ·  Arequipa, Perú"
                    android:textColor="#3B82F6"
                    android:textSize="11sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Card 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_avatar"
                android:gravity="center"
                android:text="L"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Luis P."
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Técnico Electricista"
                    android:textColor="#70FFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="★ 4.8  ·  Cusco, Perú"
                    android:textColor="#3B82F6"
                    android:textSize="11sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
