<?xml version="1.0" encoding="utf-8"?>
<!-- Raíz: LinearLayout vertical para poder fijar header + subnav y dejar scroll al contenido -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@null"
    android:paddingTop="52dp">

    <!-- ══ BARRA SUPERIOR: título + menú hamburguesa ══════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Mi Perfil"
            android:textColor="#FFFFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Botón 3 líneas → menú desplegable -->
        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_menu_hamburger"
            android:alpha="0.75"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Menú" />

    </LinearLayout>

    <!-- ══ SUB-BARRA DE NAVEGACIÓN: Perfil | Colaboraciones | Postulaciones ══ -->
    <FrameLayout
        android:id="@+id/subNavContainer"
        android:layout_width="match_parent"
        android:layout_height="42dp">

        <!-- Línea inferior separadora -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_gravity="bottom"
            android:background="#18FFFFFF" />

        <!-- Indicador deslizante (se posiciona y anima en código) -->
        <View
            android:id="@+id/subNavIndicator"
            android:layout_width="10dp"
            android:layout_height="2dp"
            android:layout_gravity="bottom|start"
            android:background="@drawable/bg_sub_nav_indicator" />

        <!-- Tabs de texto -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="3">

            <TextView
                android:id="@+id/subTabPerfil"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Perfil"
                android:textColor="#FFFFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/subTabColabs"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Colaboraciones"
                android:textColor="#50FFFFFF"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/subTabPosts"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Postulaciones"
                android:textColor="#50FFFFFF"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </FrameLayout>

    <!-- ══ CONTENIDO SCROLLEABLE ══════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:background="@null">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="100dp"
            android:paddingHorizontal="20dp">

            <!-- ══════════════════════════════════════════════ -->
            <!--            SUB-TAB 1: MI PERFIL               -->
            <!-- ══════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/layoutPerfil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Avatar grande centrado -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingBottom="24dp">

                    <TextView
                        android:id="@+id/tvAvatar"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:background="@drawable/bg_avatar"
                        android:gravity="center"
                        android:text="?"
                        android:textColor="@color/white"
                        android:textSize="36sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <!-- Chip de rol -->
                    <TextView
                        android:id="@+id/tvProfileRol"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_chip_selected"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="6dp"
                        android:text="—"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                </LinearLayout>

                <!-- ── Sección: Información ───────────────── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="INFORMACIÓN"
                    android:textColor="#40FFFFFF"
                    android:textSize="10sp"
                    android:letterSpacing="0.15" />

                <!-- Card info: email -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_glass_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <!-- Círculo gradiente con icono -->
                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_info_circle"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_email"
                            android:contentDescription="@null" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">
                        <TextView
                            android:id="@+id/tvProfileEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Correo electrónico"
                            android:textColor="#50FFFFFF"
                            android:textSize="11sp" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Card info: rol/tipo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_glass_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_info_circle"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_nav_person"
                            android:contentDescription="@null" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">
                        <TextView
                            android:id="@+id/tvInfoRol"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Tipo de cuenta"
                            android:textColor="#50FFFFFF"
                            android:textSize="11sp" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Card info: calificación -->
                <LinearLayout
                    android:id="@+id/cardRating"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_glass_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_info_circle"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_star"
                            android:contentDescription="@null" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">
                        <TextView
                            android:id="@+id/tvRating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sin calificaciones aún"
                            android:textColor="#90FFFFFF"
                            android:textSize="14sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Calificación promedio"
                            android:textColor="#50FFFFFF"
                            android:textSize="11sp" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Card info: ubicación (visible solo si tiene) -->
                <LinearLayout
                    android:id="@+id/cardLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_glass_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_info_circle"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_location"
                            android:contentDescription="@null" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">
                        <TextView
                            android:id="@+id/tvLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Ubicación"
                            android:textColor="#50FFFFFF"
                            android:textSize="11sp" />
                    </LinearLayout>

                </LinearLayout>

                <!-- ── Completa tu perfil (si le faltan datos) -->
                <LinearLayout
                    android:id="@+id/cardCompleteProfile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_complete_profile_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Completa tu perfil"
                        android:textColor="#80FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Agrega foto, habilidades y descripción\npara que las empresas te encuentren"
                        android:textColor="#50FFFFFF"
                        android:textSize="12sp"
                        android:gravity="center" />

                    <Button
                        android:id="@+id/btnEditProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="14dp"
                        android:paddingHorizontal="24dp"
                        android:background="@drawable/bg_button_white"
                        android:text="Editar perfil"
                        android:textColor="#1A0F3D"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:stateListAnimator="@null" />

                </LinearLayout>

            </LinearLayout>

            <!-- ══════════════════════════════════════════════ -->
            <!--         SUB-TAB 2: COLABORACIONES             -->
            <!-- ══════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/layoutColabs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="40dp"
                android:visibility="gone">

                <!-- Círculo vacío grande -->
                <LinearLayout
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:background="@drawable/bg_glass_card"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_nav_building"
                        android:alpha="0.25"
                        android:contentDescription="@null" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Sin colaboraciones aún"
                    android:textColor="#55FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Cuando completes proyectos con\nempresas, aparecerán aquí"
                    android:textColor="#35FFFFFF"
                    android:textSize="13sp"
                    android:gravity="center" />

            </LinearLayout>

            <!-- ══════════════════════════════════════════════ -->
            <!--         SUB-TAB 3: MIS POSTULACIONES          -->
            <!-- ══════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/layoutPosts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="40dp"
                android:visibility="gone">

                <!-- Círculo vacío grande -->
                <LinearLayout
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:background="@drawable/bg_glass_card"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_nav_search"
                        android:alpha="0.25"
                        android:contentDescription="@null" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Sin postulaciones aún"
                    android:textColor="#55FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Las convocatorias a las que apliques\naparecerán aquí"
                    android:textColor="#35FFFFFF"
                    android:textSize="13sp"
                    android:gravity="center" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
